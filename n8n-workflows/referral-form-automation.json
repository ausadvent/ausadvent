      "parameters": {
        "jsCode": "// Node 2: Map Tally fields → template placeholders\n// Handles text fields, multiple choice, and trailing spaces\n\nconst fields = $json.body.data.fields;\n\n// Helper: get value by label (trims spaces from label names)\nconst getField = (label) => {\n  const field = fields.find(f => f.label.trim() === label.trim());\n  return field?.value ?? '';\n};\n\n// Helper: get human-readable text for multiple choice fields\nconst getChoice = (label) => {\n  const field = fields.find(f => f.label.trim() === label.trim());\n  if (!field || !field.options || !field.value) return '';\n  // value is an array of selected option IDs — get the matching text\n  const selectedId = field.value[0];\n  const match = field.options.find(o => o.id === selectedId);\n  return match?.text ?? '';\n};\n\nconst firstName = getField('First name');\nconst lastName  = getField('Last name');\n\nreturn [{\n  json: {\n    // — Template placeholders (must match Google Docs {{tags}} exactly) —\n    full_name:                firstName + ' ' + lastName,\n    preferred_name_alias:     getField('Preferred name'),\n    date_of_birth:            getField('Date of birth'),\n    email:                    getField('Email'),\n    telephone:                getField('Telephone'),\n    postal_address:           getField('Postal Address'),\n    address:                  getField('Address'),\n    ndis_number:              String(getField('NDIS Number')),\n    ndis_plan_management_type: getChoice('Plan type'),\n    plan_manager_name:        getField(\"Plan Manager's details\"),\n    ndis_plan_start_date:     getField('NDIS Plan start date'),\n    ndis_plan_end_date:       getField('NDIS Plan end date'),\n    atsi_cald:                getChoice('ATSI / CALD'),\n    mental_health_diagnosis:  getField('Mental Health Diagnosis'),\n    referral_date:            new Date().toISOString().split('T')[0],\n\n    // — Metadata for Airtable (not in PDF template) —\n    first_name: firstName,\n    last_name:  lastName,\n  }\n}];"
      },
