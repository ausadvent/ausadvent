    {
      "parameters": {
        "jsCode": "// Fix: Ensure binary has .pdf extension and correct MIME type\n// The SMTP node uses the filename to determine attachment type\n// Without .pdf extension, recipients see an unknown file\n\nconst items = $input.all();\n\nfor (const item of items) {\n  if (item.binary) {\n    for (const key of Object.keys(item.binary)) {\n      const bin = item.binary[key];\n      if (!bin.fileName || !bin.fileName.endsWith('.pdf')) {\n        // Use the doc name from earlier in the workflow, or fallback\n        const docName = $('Code in JavaScript1').item.json.docName || 'Referral';\n        bin.fileName = docName.replace(/\\s+/g, '_') + '.pdf';\n      }\n      bin.mimeType = 'application/pdf';\n    }\n  }\n}\n\nreturn items;"
      },
