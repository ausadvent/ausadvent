      "parameters": {
        "jsCode": "// Node 5: Replace placeholders using HTTP Request approach\n// We pass the doc ID and data forward — the actual replacement \n// will be done by an HTTP Request node which handles OAuth automatically\n\nconst docId = $('Copy file').item.json.id;\nconst data = $('Code in JavaScript').item.json;\n\n// Build all 15 find-replace requests\nconst requests = [\n  ['{{full_name}}',                 data.full_name],\n  ['{{preferred_name_alias}}',      data.preferred_name_alias],\n  ['{{date_of_birth}}',             data.date_of_birth],\n  ['{{email}}',                     data.email],\n  ['{{telephone}}',                 data.telephone],\n  ['{{postal_address}}',            data.postal_address],\n  ['{{address}}',                   data.address],\n  ['{{ndis_number}}',               data.ndis_number],\n  ['{{ndis_plan_management_type}}', data.ndis_plan_management_type],\n  ['{{plan_manager_name}}',         data.plan_manager_name],\n  ['{{ndis_plan_start_date}}',      data.ndis_plan_start_date],\n  ['{{ndis_plan_end_date}}',        data.ndis_plan_end_date],\n  ['{{atsi_cald}}',                 data.atsi_cald],\n  ['{{mental_health_diagnosis}}',   data.mental_health_diagnosis],\n  ['{{referral_date}}',             data.referral_date],\n].map(([find, replace]) => ({\n  replaceAllText: {\n    containsText: { text: find, matchCase: true },\n    replaceText: replace || '',\n  }\n}));\n\nreturn [{ json: { \n  docId,\n  docName: $('Copy file').item.json.name,\n  requests  // Pass requests to next node\n}}];"
      },
